# ── Get 笔记开放平台 ─────────────────────────────────────────────────────────
# https://www.biji.com/openapi 申请
BIJI_API_KEY=
BIJI_CLIENT_ID=

# ── 菜谱知识库 ───────────────────────────────────────────────────────────────
# 知识库 URL 别名：https://biji.com/topic/pn5wNaO0 → 填 pn5wNaO0
BIJI_TOPIC_ID_RECIPE=
# 可选：Get 笔记 Web 端「API 设置」里的数字 topic_id（服务端精确过滤用）
# BIJI_TOPIC_NUMERIC_ID_RECIPE=

# ── Notion ───────────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations 创建 Internal Integration
NOTION_API_KEY=

# 菜谱 Notion 数据库 ID（32位 hex 或带连字符 UUID）
NOTION_DATABASE_ID_RECIPE=

# 菜谱库中「视频链接」列名（URL 类型）
NOTION_PROP_DOUYIN_URL=视频链接

# 菜谱库中用于去重的列名（文本类型，专门存 Get 笔记 ID）
NOTION_PROP_EXTERNAL_ID=Get笔记ID

# 可选：是否把 Get 笔记正文同步到 Notion 页面正文；默认开启
# NOTION_SYNC_PAGE_BODY=1

# 可选列名（库中无同名列则自动跳过）
# NOTION_PROP_BIJI_SHARE=
# NOTION_PROP_LINK_SOURCE=
# NOTION_PROP_BODY=

# ── 排查用 ───────────────────────────────────────────────────────────────────
# BIJI_SKIP_TOPIC_FILTER=1
# BIJI_PAGE_PAUSE_SEC=0.6
# BIJI_DETAIL_PAUSE_SEC=0.2
